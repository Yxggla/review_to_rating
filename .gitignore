.DS_Store
__pycache__/
*.py[cod]
.Python
.venv/
.venv-arm64/
venv/
env/
.playwright-mcp/

# Generated outputs
outputs/predictions/*.csv
outputs/metrics/*.csv
outputs/metrics/classification_reports/*.txt
outputs/metrics/error_analysis/*.csv
outputs/figures/**/*.png
outputs/logs/*
!outputs/logs/.gitkeep

# Local model checkpoints can be large.
models/*.joblib
models/distilbert_sentiment/*
models/distilbert_rating/*
!models/distilbert_sentiment/.gitkeep
!models/distilbert_rating/.gitkeep

# Local dataset files can be large. Keep only README/metadata in git.
*.zip
data/**/*.parquet
data/**/*.csv
data/**/summary.json
!data/**/README.md
!data/**/summary.example.json

# Kaggle packaging and downloaded outputs.
kaggle_upload/dataset/*.csv
kaggle_upload/*.zip
kaggle_upload/kernel/__pycache__/
kaggle_upload/kernel/*.pyc

kaggle_outputs/**
!kaggle_outputs/
!kaggle_outputs/distilbert/
!kaggle_outputs/distilbert/review_to_rating_distilbert/
!kaggle_outputs/distilbert/review_to_rating_distilbert/metrics/
!kaggle_outputs/distilbert/review_to_rating_distilbert/metrics/*.csv
!kaggle_outputs/distilbert/review_to_rating_distilbert/metrics/*.txt
