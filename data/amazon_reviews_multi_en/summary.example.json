  "validation": {
    "rows": 5000,
    "processed_csv": "data/amazon_reviews_multi_en/processed_3class/validation_3class.csv"
  },
  "test": {
    "rows": 5000,
    "processed_csv": "data/amazon_reviews_multi_en/processed_3class/test_3class.csv"
  }
}
